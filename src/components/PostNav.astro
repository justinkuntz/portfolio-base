---
import Link from "@components/Link.astro";

type NavEntry = {
  collection: string;
  slug: string;
  data: {
    title: string;
  };
};

type Props = {
  prev: NavEntry;
  next: NavEntry;
  topSpacing?: "md" | "lg";
};

const { prev, next, topSpacing = "lg" } = Astro.props;
---

<div class:list={["post-nav", `post-nav--${topSpacing}`]}>
  <Link
    href={`/${prev.collection}/${prev.slug}`}
    class="post-nav__card post-nav__card--prev"
  >
    <span class="post-nav__body">
      <span class="post-nav__label">Prev</span>
      <span class="post-nav__title">{prev.data.title}</span>
    </span>
    <svg
      class="post-nav__arrow arrow-animated arrow-animated--left post-nav__arrow--left"
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line"></line>
      <polyline points="12 5 19 12 12 19" class="arrow-animated__poly"
      ></polyline>
    </svg>
  </Link>
  <Link
    href={`/${next.collection}/${next.slug}`}
    class="post-nav__card post-nav__card--next"
  >
    <span class="post-nav__body post-nav__body--right">
      <span class="post-nav__label">Next</span>
      <span class="post-nav__title">{next.data.title}</span>
    </span>
    <svg
      class="post-nav__arrow arrow-animated"
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line"></line>
      <polyline points="12 5 19 12 12 19" class="arrow-animated__poly"
      ></polyline>
    </svg>
  </Link>
</div>

<style>
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .post-nav--md {
    margin-top: var(--space-12);
  }

  .post-nav--lg {
    margin-top: var(--space-16);
  }

  .post-nav__card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    color: currentColor;
    text-decoration: none;
    transition:
      background-color var(--transition-base),
      color var(--transition-base);
  }

  .post-nav__card:hover {
    background-color: var(--color-surface-hover);
  }

  .post-nav__card:focus-visible {
    background-color: var(--color-surface-hover);
  }

  .post-nav__card:hover .post-nav__title,
  .post-nav__card:hover .post-nav__arrow,
  .post-nav__card:focus-visible .post-nav__title,
  .post-nav__card:focus-visible .post-nav__arrow {
    color: var(--color-surface-950);
    stroke: var(--color-surface-950);
  }

  .post-nav__card--prev .post-nav__arrow--left {
    order: -1;
    transform: rotate(180deg);
  }

  .post-nav__body {
    flex: 1;
    min-width: 0;
  }

  .post-nav__body--right {
    text-align: right;
  }

  .post-nav__label {
    font-size: var(--text-sm);
    text-transform: uppercase;
    line-height: var(--leading-label, 1.3);
    letter-spacing: var(--tracking-label, 0.08em);
  }

  .post-nav__title {
    display: block;
    font-weight: var(--font-semibold);
    line-height: var(--leading-heading, 1.15);
    margin-top: var(--space-3);
    color: var(--color-surface-950);
    transition: color var(--transition-base);
  }

  .post-nav__arrow {
    flex-shrink: 0;
    stroke: currentColor;
    transition: stroke var(--transition-base);
  }
</style>
