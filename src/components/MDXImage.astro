---
/* eslint-disable @typescript-eslint/no-explicit-any */
import { Image } from "astro:assets";
import { MEDIA } from "@config/media";

const { src, alt, ...rest } = Astro.props as any;
---

<Image
  src={src}
  alt={alt ?? ""}
  widths={[...MEDIA.mdxImage.widths]}
  sizes={MEDIA.mdxImage.sizes}
  loading="lazy"
  decoding="async"
  quality={MEDIA.mdxImage.quality}
  {...rest}
/>
