---
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
const { pathname } = Astro.url;
const subpath = pathname.match(/[^/]+/g);
import { SITE, LINKS } from "@consts";
---

<header id="header" class="header">
  <Container size="xl">
    <div class="header__inner">
      <div class="header__logo">
        <a href="/" class="header__logo-link">
          <svg class="header__logo-icon" aria-hidden="true">
            <use href="/brand.svg#brand"></use>
          </svg>
          <span class="header__logo-text">{SITE.NAME}</span>
        </a>
      </div>
      <div class="header__nav-wrap">
        <nav class="header__nav">
          {
            LINKS.map((LINK) => (
              <Button
                href={LINK.HREF}
                variant={pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF ? "primary" : "ghost"}
                size="lg"
                class="header__nav-link"
              >
                {LINK.TEXT}
              </Button>
            ))
          }
        </nav>
        <div class="header__actions">
          <Button
            href="/search"
            variant={pathname === "/search" || "/" + subpath?.[0] === "search" ? "primary" : "ghost"}
            size="md"
            iconOnly
            aria-label={`Search blog posts and projects on ${SITE.NAME}`}
            class="header__action-btn header__action-btn--search"
          >
            <svg class="header__action-icon" aria-hidden="true">
              <use href="/ui.svg#search"></use>
            </svg>
          </Button>
          <div class="header__theme-toggle-wrap">
            <ThemeToggle
              id="header-theme-button"
              size="md"
              class="header__theme-toggle"
            />
          </div>
          <Button
            id="header-drawer-button"
            type="button"
            variant="ghost"
            size="md"
            iconOnly
            aria-label="Toggle drawer open and closed"
            class="header__action-btn header__action-btn--drawer"
          >
            <svg id="drawer-open" class="header__action-icon" aria-hidden="true">
              <use href="/ui.svg#menu"></use>
            </svg>
            <svg id="drawer-close" class="header__action-icon" aria-hidden="true">
              <use href="/ui.svg#x"></use>
            </svg>
          </Button>
        </div>
      </div>
    </div>
  </Container>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 5rem;
    z-index: var(--z-fixed);
  }

  .header__inner {
    position: relative;
    height: 100%;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__logo-link {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    color: currentColor;
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    transition: color var(--transition-base);
  }

  .header__logo-link:hover {
    color: var(--color-surface-700);
    text-decoration: none;
  }

  .header__logo-icon {
    width: 2.25rem;
    height: 2.25rem;
    fill: currentColor;
  }

  .header__nav-wrap {
    display: flex;
    gap: var(--space-5);
  }

  .header__nav {
    display: none;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    font-size: var(--text-xl);
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }

  /* :global() so styles apply to Button's rendered root (different component scope) */
  .header :global(.header__nav-link) {
    height: 2.5rem;
    border-radius: var(--radius-full);
    padding-inline: var(--space-4);
  }

  .header__actions {
    display: flex;
    gap: var(--space-3);
  }

  .header :global(.header__action-btn) {
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-2);
  }

  .header :global(.header__action-btn--search) {
    display: none;
  }

  @media (min-width: 768px) {
    .header :global(.header__action-btn--search) {
      display: inline-flex;
    }
  }

  .header__theme-toggle-wrap {
    display: none;
  }

  @media (min-width: 768px) {
    .header__theme-toggle-wrap {
      display: inline-flex;
      align-items: center;
    }
  }

  .header :global(.header__action-icon) {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .header :global(.header__action-btn--drawer) {
    display: inline-flex;
  }

  @media (min-width: 768px) {
    .header :global(.header__action-btn--drawer) {
      display: none;
    }
  }

  .header :global(#header-drawer-button) :global(#drawer-open) {
    display: block;
  }

  .header :global(#header-drawer-button) :global(#drawer-close) {
    display: none;
  }

  .header :global(#header-drawer-button.open) :global(#drawer-open) {
    display: none;
  }

  .header :global(#header-drawer-button.open) :global(#drawer-close) {
    display: block;
  }
</style>

<script is:inline>
  function toggleDrawer() {
    const drawer = document.getElementById("drawer");
    const drawerButton = document.getElementById("header-drawer-button");
    drawer?.classList.toggle("open");
    drawerButton?.classList.toggle("open");
  }

  function initializeDrawerButton() {
    const drawerButton = document.getElementById("header-drawer-button");
    drawerButton?.addEventListener("click", toggleDrawer);
  }

  document.addEventListener("astro:after-swap", initializeDrawerButton);
  initializeDrawerButton();
</script>
