---
import Container from "@components/Container.astro";
const { pathname } = Astro.url;
import { SITE, LINKS } from "@consts";
---

<header id="header" class="header">
  <Container size="xl">
    <div class="header__inner">
      <!-- Logo -->
      <div class="header__logo">
        <a href="/" class="logo-link">
          <svg class="logo-icon">
            <use href="/brand.svg#brand"></use>
          </svg>
          <div class="logo-text">
            {SITE.NAME}
          </div>
        </a>
      </div>
      <!-- Nav -->
      <div class="header__nav-wrapper">
        <nav class="header__nav">
          {
            LINKS.map((LINK) => (
              <a
                href={LINK.HREF}
                class:list={["nav-link", { "nav-link--active": pathname === LINK.HREF }]}
              >
                {LINK.TEXT}
              </a>
            ))
          }
        </nav>
        <div class="header__actions">
          <!-- Search -->
          <a
            href="/search"
            aria-label={`Search blog posts and projects on ${SITE.NAME}`}
            class:list={["action-button", { "action-button--active": pathname === "/search" }]}
          >
            <svg class="action-icon">
              <use href="/ui.svg#search"></use>
            </svg>
          </a>
          <!-- Dark/Light Mode -->
          <button
            id="header-theme-button"
            aria-label={`Toggle light and dark theme`}
            class="action-button"
          >
            <svg class="action-icon theme-icon theme-icon--light">
              <use href="/ui.svg#sun"></use>
            </svg>
            <svg class="action-icon theme-icon theme-icon--dark">
              <use href="/ui.svg#moon"></use>
            </svg>
          </button>
          <!-- Drawer Button -->
          <button
            id="header-drawer-button"
            aria-label={`Toggle drawer open and closed`}
            class="action-button action-button--drawer"
          >
            <svg id="drawer-open" class="action-icon">
              <use href="/ui.svg#menu"></use>
            </svg>
            <svg id="drawer-close" class="action-icon">
              <use href="/ui.svg#x"></use>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </Container>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-fixed);
    height: 5rem;
    background-color: transparent;
    transition: background-color var(--transition-base);
  }

  .header.scrolled {
    background-color: color-mix(in srgb, var(--surface-1) 75%, transparent);
    backdrop-filter: blur(10px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 5rem;
  }

  /* Logo */
  .header__logo {
    font-weight: var(--font-semibold);
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-1);
    text-decoration: none;
    font-size: var(--text-xl);
    transition: color var(--transition-base);
  }

  .logo-link:hover {
    color: var(--color-primary);
  }

  .logo-icon {
    width: 2.25rem;
    height: 2.25rem;
    fill: currentColor;
  }

  /* Navigation */
  .header__nav-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .header__nav {
    display: none;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-lg);
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    padding-inline: var(--space-md);
    color: var(--text-2);
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .nav-link:hover {
    background-color: color-mix(in srgb, var(--text-1) 10%, transparent);
    color: var(--text-1);
  }

  .nav-link--active {
    background-color: var(--text-1);
    color: var(--surface-1);
  }

  /* Actions */
  .header__actions {
    display: flex;
    gap: var(--space-md);
  }

  .action-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-sm);
    border: none;
    border-radius: var(--radius-full);
    background-color: transparent;
    color: var(--text-1);
    cursor: pointer;
    transition: background-color var(--transition-base);
  }

  .action-button:hover {
    background-color: color-mix(in srgb, var(--text-1) 5%, transparent);
  }

  .action-button--active {
    pointer-events: none;
    background-color: var(--text-1);
    color: var(--surface-1);
  }

  .action-button--drawer {
    display: flex;
  }

  @media (min-width: 768px) {
    .action-button {
      display: flex;
    }

    .action-button--drawer {
      display: none;
    }
  }

  .action-icon {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }

  /* Theme icons */
  .theme-icon--light {
    display: block;
  }

  .theme-icon--dark {
    display: none;
  }

  html.dark .theme-icon--light {
    display: none;
  }

  html.dark .theme-icon--dark {
    display: block;
  }

  /* Drawer button states */
  #header-drawer-button > #drawer-open {
    display: block;
  }

  #header-drawer-button > #drawer-close {
    display: none;
  }

  #header-drawer-button.open > #drawer-open {
    display: none;
  }

  #header-drawer-button.open > #drawer-close {
    display: block;
  }
</style>

<script is:inline>
  function toggleDrawer() {
    const drawer = document.getElementById("drawer");
    const drawerButton = document.getElementById("header-drawer-button");
    drawer?.classList.toggle("open");
    drawerButton?.classList.toggle("open");
  }

  function initializeDrawerButton() {
    const drawerButton = document.getElementById("header-drawer-button");
    drawerButton?.addEventListener("click", toggleDrawer);
  }

  function handleScroll() {
    const header = document.getElementById("header");
    if (window.scrollY > 0) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  }

  function initializeHeader() {
    initializeDrawerButton();
    handleScroll();
    window.addEventListener("scroll", handleScroll);
  }

  document.addEventListener("astro:after-swap", initializeHeader);
  initializeHeader();
</script>
