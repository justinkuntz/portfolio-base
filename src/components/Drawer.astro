---
import { SITE, LINKS } from "@consts";
const { pathname } = Astro.url;
---

<div id="drawer" class="drawer">
  <div class="drawer__content">
    <nav class="drawer__nav">
      {
        LINKS.map((LINK) => (
          <a
            href={LINK.HREF}
            class:list={["drawer__link", { "drawer__link--active": pathname === LINK.HREF }]}
          >
            {LINK.TEXT}
          </a>
        ))
      }
    </nav>

    <div class="drawer__actions">
      <a
        href="/search"
        aria-label={`Search blog posts and projects on ${SITE.NAME}`}
        class:list={["drawer__action", { "drawer__action--active": pathname === "/search" }]}
      >
        <svg class="drawer__icon">
          <use href="/ui.svg#search"></use>
        </svg>
      </a>

      <a
        href="/rss.xml"
        target="_blank"
        aria-label={`Rss feed for ${SITE.NAME}`}
        class="drawer__action"
      >
        <svg class="drawer__icon">
          <use href="/ui.svg#rss"></use>
        </svg>
      </a>

      <button
        id="drawer-theme-button"
        aria-label={`Toggle light and dark theme`}
        class="drawer__action"
      >
        <svg class="drawer__icon drawer__theme-icon drawer__theme-icon--light">
          <use href="/ui.svg#sun"></use>
        </svg>
        <svg class="drawer__icon drawer__theme-icon drawer__theme-icon--dark">
          <use href="/ui.svg#moon"></use>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .drawer {
    position: fixed;
    top: 5rem;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: var(--z-sticky);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--surface-2);
    overflow: hidden;
    transform: translateY(-100%);
    opacity: 0;
    transition: transform var(--transition-base), opacity var(--transition-base);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .drawer {
      display: none;
    }
  }

  .drawer.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .drawer__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3xl);
    padding: var(--space-2xl);
  }

  .drawer__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  .drawer__link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-xl);
    font-weight: var(--font-medium);
    color: var(--text-2);
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .drawer__link:hover {
    background-color: color-mix(in srgb, var(--text-1) 10%, transparent);
    color: var(--text-1);
  }

  .drawer__link--active {
    background-color: var(--text-1);
    color: var(--surface-1);
    pointer-events: none;
  }

  .drawer__actions {
    display: flex;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .drawer__action {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: var(--space-sm);
    border: none;
    border-radius: var(--radius-full);
    background-color: transparent;
    color: var(--text-1);
    text-decoration: none;
    cursor: pointer;
    transition: background-color var(--transition-base);
  }

  .drawer__action:hover {
    background-color: color-mix(in srgb, var(--text-1) 10%, transparent);
  }

  .drawer__action--active {
    background-color: var(--text-1);
    color: var(--surface-1);
    pointer-events: none;
  }

  .drawer__icon {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }

  /* Theme icons */
  .drawer__theme-icon--light {
    display: block;
  }

  .drawer__theme-icon--dark {
    display: none;
  }

  html.dark .drawer__theme-icon--light {
    display: none;
  }

  html.dark .drawer__theme-icon--dark {
    display: block;
  }
</style>

<script>
  function initializeDrawer() {
    const drawer = document.getElementById('drawer');
    const drawerButton = document.getElementById('header-drawer-button');
    const drawerLinks = drawer?.querySelectorAll('.drawer__link');

    // Close drawer when a link is clicked
    drawerLinks?.forEach(link => {
      link.addEventListener('click', () => {
        drawer?.classList.remove('open');
        drawerButton?.classList.remove('open');
      });
    });
  }

  document.addEventListener('astro:after-swap', initializeDrawer);
  initializeDrawer();
</script>
