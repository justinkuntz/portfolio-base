---
import Button from "@components/Button.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { SITE, LINKS } from "@consts";
const { pathname } = Astro.url;
const subpath = pathname.match(/[^/]+/g);
---

<div id="drawer" class="drawer">
  <nav class="drawer__nav">
    {
      LINKS.map((LINK) => (
        <Button
          href={LINK.HREF}
          variant={pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF ? "primary" : "ghost"}
          size="lg"
          class="drawer__nav-link"
        >
          {LINK.TEXT}
        </Button>
      ))
    }
  </nav>
  <div class="drawer__actions">
    <Button
      href="/search"
      variant={pathname === "/search" || "/" + subpath?.[0] === "search" ? "primary" : "ghost"}
      size="md"
      iconOnly
      aria-label={`Search blog posts and projects on ${SITE.NAME}`}
      class="drawer__action-btn"
    >
      <svg class="drawer__action-icon" aria-hidden="true">
        <use href="/ui.svg#search"></use>
      </svg>
    </Button>
    <Button
      href="/rss.xml"
      external
      variant="ghost"
      size="md"
      iconOnly
      aria-label={`RSS feed for ${SITE.NAME}`}
      class="drawer__action-btn"
    >
      <svg class="drawer__action-icon" aria-hidden="true">
        <use href="/ui.svg#rss"></use>
      </svg>
    </Button>
    <ThemeToggle
      id="drawer-theme-button"
      size="lg"
      class="drawer__theme-toggle"
    />
  </div>
</div>

<style>
  .drawer {
    position: fixed;
    top: 5rem; /* below header */
    left: 0;
    right: 0;
    bottom: 0;
    height: 0;
    z-index: 40;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-100);
    transition: height var(--transition-base);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .drawer {
      display: none;
    }
  }

  .drawer.open {
    height: calc(100vh - 5rem);
    pointer-events: auto;
  }

  .drawer__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  /* :global() so styles apply to Button's rendered root */
  .drawer :global(.drawer__nav-link) {
    padding-inline: var(--space-3);
    padding-block: var(--space-1);
    border-radius: var(--radius-full);
    font-size: var(--text-xl);
  }

  .drawer__actions {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .drawer :global(.drawer__action-btn) {
    width: 2.75rem;
    height: 2.75rem;
    padding: var(--space-2);
  }

  .drawer :global(.drawer__action-icon) {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .drawer :global(.drawer__theme-toggle) {
    flex-shrink: 0;
  }
</style>
