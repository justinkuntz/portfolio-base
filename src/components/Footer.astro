---
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import Link from "@components/Link.astro";
import { SITE, SOCIALS } from "@consts";
import BackToTop from "@components/BackToTop.astro";
---

<footer class="footer animate">
  <Container size="xl">
    <div class="footer__top">
      <div class="footer__back">
        <BackToTop />
      </div>
    </div>
    <div class="footer__grid">
      <div class="footer__copy">
        &copy; {new Date().getFullYear()}
        {SITE.NAME}. All rights reserved. <Link href="/legal/privacy">Privacy Policy</Link>
        and
        <Link href="/legal/terms">Terms of Use.</Link>
      </div>
      <div class="footer__socials">
        <Button
          href="/rss.xml"
          external
          variant="ghost"
          size="md"
          iconOnly
          aria-label={`RSS feed for ${SITE.NAME}`}
          class="footer__social-btn footer__social-btn--rss"
        >
          <svg class="footer__social-icon" aria-hidden="true">
            <use href="/ui.svg#rss"></use>
          </svg>
        </Button>
        {
          SOCIALS.map((SOCIAL) => (
            <a
              href={SOCIAL.HREF}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
              class="footer__social-link"
            >
              <svg class="footer__social-icon footer__social-icon--fill" aria-hidden="true">
                <use href={`/social.svg#${SOCIAL.ICON}`}></use>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</footer>

<style>
  .footer {
    background-color: var(--color-surface-100);
  }

  .footer__top {
    position: relative;
    padding-bottom: var(--space-6);
    padding-top: var(--space-4);
  }

  .footer__back {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .footer__back {
      justify-content: flex-end;
    }
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .footer__copy {
    font-size: var(--text-sm);
    color: var(--color-surface-950);
  }

  .footer__copy a {
    color: currentColor;
    transition: color var(--transition-base);
  }

  .footer__copy a:hover {
    color: var(--color-surface-950);
  }

  .footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    align-items: center;
    order: 1;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .footer__socials {
      order: 2;
      justify-content: flex-end;
    }
  }

  .footer :global(.footer__social-btn) {
    width: 2.5rem;
    height: 2.5rem;
    min-width: 2.5rem;
    min-height: 2.5rem;
    padding: var(--space-2);
  }

  .footer__social-btn--rss {
    display: none;
  }

  @media (min-width: 768px) {
    .footer__social-btn--rss {
      display: inline-flex;
    }
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-2);
    border-radius: var(--radius-full);
    color: currentColor;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .footer__social-link:hover {
    background-color: rgb(from var(--color-surface-950) r g b / 0.05);
    color: var(--color-surface-950);
  }

  .footer__social-icon {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .footer__social-icon--fill {
    fill: currentColor;
    stroke: none;
  }

  .footer__social-link:hover .footer__social-icon--fill {
    fill: var(--color-surface-950);
  }
</style>
