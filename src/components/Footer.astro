---
import Container from "@components/Container.astro";

import { SITE, SOCIALS } from "@consts";
import BackToTop from "@components/BackToTop.astro";
---

<footer class="footer animate">
  <Container size="xl">
    <div class="footer__back-to-top">
      <BackToTop />
    </div>
    <div class="footer__content">
      <div class="footer__info">
        <p class="footer__copyright">
          &copy; {new Date().getFullYear()}
          {SITE.NAME}. All rights reserved.
        </p>
        <div class="footer__legal">
          <a href="/legal/privacy" class="footer__link">
            Privacy Policy
          </a>
          <span class="footer__separator">and</span>
          <a href="/legal/terms" class="footer__link">
            Terms of Use
          </a>
        </div>
      </div>

      <div class="footer__social">
        <div class="social-links">
          <a
            href="/rss.xml"
            target="_blank"
            aria-label={`Rss feed for ${SITE.NAME}`}
            class="social-link"
          >
            <svg class="social-icon">
              <use href="/ui.svg#rss"></use>
            </svg>
          </a>
          {
            SOCIALS.map((SOCIAL) => (
              <a
                href={SOCIAL.HREF}
                target="_blank"
                aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
                class="social-link"
              >
                <svg class="social-icon">
                  <use href={`/social.svg#${SOCIAL.ICON}`} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</footer>

<style>
  .footer {
    padding-block: var(--space-lg);
    background-color: var(--surface-2);
    font-size: var(--text-sm);
    color: var(--text-2);
  }

  .footer__back-to-top {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-bottom: var(--space-lg);
  }

  @media (min-width: 640px) {
    .footer__back-to-top {
      justify-content: flex-end;
    }
  }

  .footer__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 640px) {
    .footer__content {
      grid-template-columns: 1fr auto;
    }
  }

  .footer__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer__copyright {
    margin: 0;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
  }

  .footer__link {
    color: var(--text-2);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer__link:hover {
    color: var(--text-1);
  }

  .footer__separator {
    color: var(--text-3);
  }

  .footer__social {
    display: flex;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .footer__social {
      justify-content: flex-end;
      order: 2;
    }
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--text-2);
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .social-link:hover {
    background-color: color-mix(in srgb, var(--text-1) 10%, transparent);
    color: var(--text-1);
  }

  .social-icon {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
</style>
