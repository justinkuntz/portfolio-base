---
/**
 * Button Component
 *
 * A flexible button component with multiple variants, sizes, and configurations.
 * Can render as a button or link depending on whether href is provided.
 *
 * @example
 * <!-- Primary button -->
 * <Button variant="primary">Click me</Button>
 *
 * @example
 * <!-- Link button with icon -->
 * <Button href="/projects" variant="primary" iconRight="arrow">
 *   See my work
 * </Button>
 *
 * @example
 * <!-- Ghost button with left icon -->
 * <Button variant="ghost" iconLeft="arrow-left" size="sm">
 *   Back
 * </Button>
 */

type Props = {
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  iconLeft?: string;
  iconRight?: string;
  external?: boolean;
  class?: string;
  [key: string]: any;
};

const {
  variant = 'primary',
  size = 'md',
  href,
  iconLeft,
  iconRight,
  external = false,
  class: className,
  ...rest
} = Astro.props;

---

{href ? (
  <a
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener noreferrer' : undefined}
    class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
    {...rest}
  >
  {iconLeft && (
    <svg class="btn__icon btn__icon--left" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
      {iconLeft === 'arrow-left' && (
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      )}
      {iconLeft === 'arrow' && (
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      )}
    </svg>
  )}

    <span class="btn__content">
      <slot />
    </span>

    {iconRight && (
      <svg class="btn__icon btn__icon--right" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        {iconRight === 'arrow' && (
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        )}
        {iconRight === 'arrow-left' && (
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        )}
      </svg>
    )}
  </a>
) : (
  <button
    type="button"
    class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
    {...rest}
  >
    {iconLeft && (
      <svg class="btn__icon btn__icon--left" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        {iconLeft === 'arrow-left' && (
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        )}
        {iconLeft === 'arrow' && (
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        )}
      </svg>
    )}

    <span class="btn__content">
      <slot />
    </span>

    {iconRight && (
      <svg class="btn__icon btn__icon--right" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        {iconRight === 'arrow' && (
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        )}
        {iconRight === 'arrow-left' && (
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        )}
      </svg>
    )}
  </button>
)}

<style>
  /* ==========================================================================
     Base Button Styles
     ========================================================================== */

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: var(--font-sans);
    font-weight: var(--font-medium);
    text-decoration: none;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* ==========================================================================
     Size Variants
     ========================================================================== */

  .btn--sm {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    gap: var(--space-xs);
  }

  .btn--md {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-base);
  }

  .btn--lg {
    padding: var(--space-md) var(--space-xl);
    font-size: var(--text-lg);
  }

  /* ==========================================================================
     Color Variants
     ========================================================================== */

  /* Primary */
  .btn--primary {
    background-color: var(--text-1);
    color: var(--surface-1);
    box-shadow: var(--shadow-sm);
  }

  .btn--primary:hover {
    background-color: var(--text-2);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .btn--primary:active {
    transform: translateY(0);
    box-shadow: var(--shadow-sm);
  }

  /* Secondary */
  .btn--secondary {
    background-color: var(--surface-2);
    color: var(--text-1);
    border: 1px solid var(--border-1);
  }

  .btn--secondary:hover {
    background-color: var(--surface-3);
    border-color: var(--border-2);
  }

  /* Outline */
  .btn--outline {
    background-color: transparent;
    color: var(--text-1);
    border: 1px solid var(--border-2);
  }

  .btn--outline:hover {
    background-color: color-mix(in srgb, var(--text-1) 5%, transparent);
    border-color: var(--text-1);
  }

  /* Ghost */
  .btn--ghost {
    background-color: transparent;
    color: var(--text-2);
    border: none;
  }

  .btn--ghost:hover {
    background-color: color-mix(in srgb, var(--text-1) 5%, transparent);
    color: var(--text-1);
  }

  /* ==========================================================================
     Icon Styles
     ========================================================================== */

  .btn__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .btn--sm .btn__icon {
    width: 1rem;
    height: 1rem;
  }

  .btn--lg .btn__icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .btn__icon--right {
    margin-left: calc(var(--space-xs) * -1);
    transition: transform var(--transition-base);
  }

  .btn:hover .btn__icon--right {
    transform: translateX(2px);
  }

  .btn__icon--left {
    margin-right: calc(var(--space-xs) * -1);
    transition: transform var(--transition-base);
  }

  .btn:hover .btn__icon--left {
    transform: translateX(-2px);
  }

  .btn__content {
    display: inline-block;
  }
</style>
