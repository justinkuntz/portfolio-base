---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import { CONTACT } from "@consts";

const searchParams = Astro.url.searchParams;
const statusParam = searchParams.get("status");
const reasonParam = searchParams.get("reason");

const statusCopy = (() => {
  if (statusParam === "success") {
    return {
      tone: "success",
      text: "Transmission received. Grogu will review it between training sessions.",
    };
  }
  if (statusParam === "error") {
    const text =
      reasonParam === "rate-limit"
        ? "You're sending messages a bit too quickly. Please wait a moment and try again."
        : "We couldn't send your message. Please try again in a moment.";
    return { tone: "error", text };
  }
  return null;
})();
---

<PageLayout title={CONTACT.TITLE} description={CONTACT.DESCRIPTION}>
  <Container size="lg">
    <section class="contact">
      <div class="contact__grid">
        <div class="contact__intro">
          <p class="contact__label">{CONTACT.TITLE}</p>
          <h1 class="contact__title">
            Send a transmission to the covert
          </h1>
          <p class="contact__description">
            Have a mission, a collaboration, or a discreet request that needs a
            steady hand? Send the details and Grogu will respond when the ship
            is back in range.
          </p>
          <ul class="contact__list">
            <li class="contact__list-item">
              <span class="contact__list-label">Availability</span>
              <span>Accepting new missions this season.</span>
            </li>
            <li class="contact__list-item">
              <span class="contact__list-label">Response time</span>
              <span>Usually within 48 hours, unless hyperspace gets noisy.</span>
            </li>
          </ul>
        </div>
        <div class="contact__form-wrap">
          {
            statusCopy && (
              <div
                class={`contact__status contact__status--${statusCopy.tone}`}
              >
                {statusCopy.text}
              </div>
            )
          }
          <form
            id="contact-form"
            action="/api/contact"
            method="post"
            class="contact__form"
            novalidate
          >
            <input type="hidden" name="startedAt" id="contact-started" />
            <label class="sr-only" for="contact-company">Company</label>
            <input
              id="contact-company"
              name="company"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              class="contact__hidden"
            />

            <div class="contact__field">
              <label class="contact__label" for="contact-name">Name</label>
              <input
                id="contact-name"
                name="name"
                type="text"
                required
                minlength="2"
                placeholder="Din Djarin"
                class="contact__input"
              />
            </div>

            <div class="contact__field">
              <label class="contact__label" for="contact-email">Email</label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                placeholder="din@covert.space"
                class="contact__input"
              />
            </div>

            <div class="contact__field">
              <div class="contact__field-head">
                <label class="contact__label" for="contact-message">Message</label>
                <span class="contact__hint">Minimum 20 characters</span>
              </div>
              <textarea
                id="contact-message"
                name="message"
                required
                minlength="20"
                rows="6"
                placeholder="Share the mission, timeline, constraints, and anything Grogu should know before boarding."
                class="contact__input contact__textarea"
              ></textarea>
            </div>

            <div class="contact__submit-wrap">
              <p class="contact__hint">
                By submitting you agree to receive a reply at the email address
                you provided.
              </p>
              <Button type="submit" variant="primary" size="lg" class="contact__submit">
                <span class="inline" data-submit-text>Send transmission</span>
              </Button>
              <p
                id="contact-status"
                role="status"
                aria-live="polite"
                class="contact__status-msg"
                hidden
              >
              </p>
            </div>
          </form>
        </div>
      </div>
    </section>
  </Container>
</PageLayout>

<style>
  .contact {
    padding-block: var(--space-24);
  }

  .contact__grid {
    display: grid;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-20);
    }
  }

  .contact__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact__label {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    line-height: var(--leading-label);
    letter-spacing: var(--tracking-caps);
    color: var(--color-text-subtle);
  }

  .contact__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-semibold);
    color: var(--color-surface-950);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    max-inline-size: var(--measure-title);
    text-wrap: balance;
    margin: 0;
  }

  @media (min-width: 768px) {
    .contact__title {
      font-size: var(--text-5xl);
    }
  }

  .contact__description {
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    max-inline-size: var(--measure-copy);
    text-wrap: pretty;
    color: var(--color-text-muted);
    margin: 0;
  }

  .contact__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    color: var(--color-text-subtle);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact__list-item {
    display: flex;
    gap: var(--space-3);
    line-height: var(--leading-body);
  }

  .contact__list-label {
    font-weight: var(--font-medium);
    color: var(--color-surface-950);
  }

  .contact__form-wrap {
    background-color: var(--color-surface-50);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-surface-300);
    box-shadow: var(--shadow-sm);
    padding: var(--space-6);
  }

  @media (min-width: 640px) {
    .contact__form-wrap {
      padding: var(--space-8);
    }
  }

  .contact__status {
    margin-bottom: var(--space-6);
    border-radius: var(--radius-md);
    border: 1px solid;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
  }

  .contact__status--success {
    border-color: var(--color-success-border);
    background-color: var(--color-success-surface);
    color: var(--color-success-text);
  }

  .contact__status--error {
    border-color: var(--color-error-border);
    background-color: var(--color-error-surface);
    color: var(--color-error-text);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact__field-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-sm);
  }

  .contact__hint {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin: 0;
  }

  .contact__input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-surface-300);
    background-color: var(--color-surface-50);
    color: var(--color-surface-950);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    outline: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .contact__input:focus-visible {
    border-color: var(--color-form-focus-border);
    box-shadow: 0 0 0 2px var(--color-focus-ring);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .contact__hidden {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .contact__submit-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact__submit {
    width: 100%;
  }

  .contact__submit:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .contact__status-msg {
    font-size: var(--text-sm);
    margin: 0;
  }

  #contact-status[data-variant="success"] {
    color: var(--color-success-text-strong);
  }

  #contact-status[data-variant="error"] {
    color: var(--color-error-text-strong);
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("contact-status");
  const submitButton = form?.querySelector("button[type=submit]") as HTMLButtonElement | null | undefined;
  const startedAtInput = document.getElementById("contact-started") as HTMLInputElement | null;

  function setTimestamp() {
    if (startedAtInput) {
      startedAtInput.value = Date.now().toString();
    }
  }

  function setStatus(message: string, variant: string) {
    if (!status) return;
    status.textContent = message;
    status.dataset.variant = variant;
    status.hidden = false;
  }

  function clearStatus() {
    if (!status) return;
    status.textContent = "";
    status.removeAttribute("data-variant");
    status.hidden = true;
  }

  async function handleSubmit(event: Event) {
    event.preventDefault();
    if (!form || !submitButton) return;

    clearStatus();

    const formData = new FormData(form);
    const message = (formData.get("message") || "").toString().trim();

    if (message.length < 20) {
      setStatus(
        "Please include at least 20 characters so I have context.",
        "error",
      );
      return;
    }

    submitButton.disabled = true;

    formData.set("startedAt", startedAtInput?.value || Date.now().toString());

    try {
      const response = await fetch(form.action, {
        method: "POST",
        headers: {
          "X-Requested-With": "contact-form",
        },
        body: formData,
      });

      const payload = await response.json().catch(() => null);

      if (!response.ok) {
        throw new Error(
          payload?.message ||
            "We couldn't send your message. Please try again.",
        );
      }

      form.reset();
      setTimestamp();
      setStatus(payload?.message || "Thanks for reaching out!", "success");
    } catch (error) {
      const fallback =
        "We couldn't send your message. Please try again in a moment.";
      setStatus(error instanceof Error ? error.message : fallback, "error");
    } finally {
      submitButton.disabled = false;
    }
  }

  function init() {
    setTimestamp();
    form?.addEventListener("submit", handleSubmit);
  }

  init();
  document.addEventListener("astro:after-swap", () => {
    clearStatus();
    setTimestamp();
  });
</script>
