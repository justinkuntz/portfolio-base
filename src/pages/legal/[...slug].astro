---
import { getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { formatDate } from "@lib/utils";
import { SITE } from "@consts";

// Create the static pages for legal docs
export async function getStaticPaths() {
  const docs = await getCollection("legal");
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: doc,
  }));
}

const docs = await getCollection("legal");
const slug = Astro.params.slug;
const doc = docs.find((item) => item.id === slug);

if (!doc) {
  return Astro.redirect("/");
}

const { title, date } = doc.data;
const { Content } = await render(doc);
---

<PageLayout
  seo={{
    title: doc.data.seo?.title ?? title,
    description: doc.data.seo?.description ?? `${title} for ${SITE.NAME}`,
    generatedImage: true,
    noindex: doc.data.seo?.noindex,
    kind: "legal",
  }}
>
  <Container size="xl">
    <div class="animate">
      <div class="page-heading">
        {title}
      </div>
      <p class="legal-updated">
        Last updated: {formatDate(date)}
      </p>
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>

<style>
  .legal-updated {
    font-weight: 400;
    opacity: 0.85;
    margin: 0;
  }
</style>
