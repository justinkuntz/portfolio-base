---
import { getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";
import PostNav from "@components/PostNav.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const items = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const slug = Astro.params.slug;
const post = items.find((item) => item.id === slug);

if (!post) {
  return Astro.redirect("/blog");
}

const { Content } = await render(post);

const index = items.findIndex((x) => x.id === post.id);
const prev = items[(index - 1 + items.length) % items.length];
const next = items[(index + 1) % items.length];
---

<PageLayout
  seo={{
    title: post.data.seo?.title ?? post.data.title,
    description: post.data.seo?.description ?? post.data.description,
    image: post.data.seo?.image ?? post.data.heroImage,
    imageAlt: post.data.seo?.imageAlt ?? post.data.heroImageAlt,
    generatedImage: true,
    noindex: post.data.seo?.noindex,
    kind: "blog",
    type: "article",
    publishedTime: post.data.date,
    tags: post.data.tags,
  }}
>
  <Container size="xl">
    <div class="animate">
      <BackToPrev href="/blog"> Back to blog </BackToPrev>
    </div>
    <div class="post-header">
      <h1 class="post-title animate">
        {post.data.title}
      </h1>
      <div class="post-meta animate">
        <span class="post-meta__item">
          <svg class="post-meta__icon" aria-hidden="true">
            <use href="/ui.svg#calendar"></use>
          </svg>
          <FormattedDate date={post.data.date} />
        </span>
        <span class="post-meta__item">
          <svg class="post-meta__icon" aria-hidden="true">
            <use href="/ui.svg#book-open"></use>
          </svg>
          {readingTime(post.body ?? "")}
        </span>
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
    <PostNav prev={prev} next={next} topSpacing="lg" />
  </Container>
</PageLayout>

<style>
  .post-header {
    margin-block: var(--space-12);
  }

  .post-title {
    font-size: var(--text-5xl);
    font-weight: var(--font-semibold);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    max-inline-size: var(--measure-title);
    text-wrap: balance;
    color: var(--color-surface-950);
    margin: 0;
  }

  @media (min-width: 1024px) {
    .post-title {
      font-size: var(--text-6xl);
    }
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    text-transform: uppercase;
    line-height: var(--leading-label);
    letter-spacing: var(--tracking-label);
    opacity: 0.85;
  }

  .post-meta__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .post-meta__icon {
    width: 1.25rem;
    height: 1.25rem;
    stroke: currentColor;
    fill: none;
  }

</style>
