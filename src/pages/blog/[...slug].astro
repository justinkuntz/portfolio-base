---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Link from "@components/Link.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { collection } = post;
const { Content } = await post.render();

const items = (await getCollection(collection))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const index = items.findIndex((x) => x.slug === post.slug);
const prev = items[(index - 1 + items.length) % items.length];
const next = items[(index + 1) % items.length];
---

<PageLayout title={post.data.title} description={post.data.description}>
  <Container size="xl">
    <div class="animate">
      <BackToPrev href="/blog"> Back to blog </BackToPrev>
    </div>
    <div class="post-header">
      <h1 class="post-title animate">
        {post.data.title}
      </h1>
      <div class="post-meta animate">
        <span class="post-meta__item">
          <svg class="post-meta__icon" aria-hidden="true">
            <use href="/ui.svg#calendar"></use>
          </svg>
          <FormattedDate date={post.data.date} />
        </span>
        <span class="post-meta__item">
          <svg class="post-meta__icon" aria-hidden="true">
            <use href="/ui.svg#book-open"></use>
          </svg>
          {readingTime(post.body)}
        </span>
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
    <div class="post-nav">
      <Link href={`/${prev.collection}/${prev.slug}`} class="post-nav__card post-nav__card--prev">
        <span class="post-nav__body">
          <span class="post-nav__label">Prev</span>
          <span class="post-nav__title">{prev.data.title}</span>
        </span>
        <svg class="post-nav__arrow arrow-animated arrow-animated--left post-nav__arrow--left" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line"></line>
          <polyline points="12 5 19 12 12 19" class="arrow-animated__poly"></polyline>
        </svg>
      </Link>
      <Link href={`/${next.collection}/${next.slug}`} class="post-nav__card post-nav__card--next">
        <span class="post-nav__body post-nav__body--right">
          <span class="post-nav__label">Next</span>
          <span class="post-nav__title">{next.data.title}</span>
        </span>
        <svg class="post-nav__arrow arrow-animated" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line"></line>
          <polyline points="12 5 19 12 12 19" class="arrow-animated__poly"></polyline>
        </svg>
      </Link>
    </div>
  </Container>
</PageLayout>

<style>
  .post-header {
    margin-block: var(--space-12);
  }

  .post-title {
    font-size: var(--text-5xl);
    font-weight: var(--font-semibold);
    color: var(--color-surface-950);
    margin: 0;
  }

  @media (min-width: 1024px) {
    .post-title {
      font-size: var(--text-6xl);
    }
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    text-transform: uppercase;
    opacity: 0.85;
  }

  .post-meta__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .post-meta__icon {
    width: 1.25rem;
    height: 1.25rem;
    stroke: currentColor;
    fill: none;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-16);
  }

  @media (min-width: 640px) {
    .post-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .post-nav__card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid rgb(from var(--color-surface-950) r g b / 0.15);
    border-radius: var(--radius-lg);
    color: currentColor;
    text-decoration: none;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .post-nav__card:hover {
    background-color: rgb(from var(--color-surface-950) r g b / 0.05);
  }

  .post-nav__card:hover .post-nav__title,
  .post-nav__card:hover .post-nav__arrow {
    color: var(--color-surface-950);
    stroke: var(--color-surface-950);
  }

  .post-nav__card--prev {
    flex-direction: row;
  }

  .post-nav__card--prev .post-nav__arrow {
    order: -1;
    transform: rotate(180deg);
  }

  .post-nav__card--next .post-nav__body {
    text-align: right;
  }

  .post-nav__body {
    flex: 1;
    min-width: 0;
  }

  .post-nav__label {
    font-size: var(--text-sm);
    text-transform: uppercase;
  }

  .post-nav__title {
    display: block;
    font-weight: var(--font-semibold);
    margin-top: var(--space-3);
    color: var(--color-surface-950);
    transition: color var(--transition-base);
  }

  .post-nav__arrow {
    flex-shrink: 0;
    stroke: currentColor;
    transition: stroke var(--transition-base);
  }
</style>
