---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import Image from "astro/components/Image.astro";
import PostNav from "@components/PostNav.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { collection } = project;
const { Content } = await project.render();

const items = (await getCollection(collection))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const index = items.findIndex((x) => x.slug === project.slug);
const prev = items[(index - 1 + items.length) % items.length];
const next = items[(index + 1) % items.length];
---

<PageLayout
  title={project.data.title}
  description={project.data.description || ""}
>
  <Container size="xl">
    <div class="project-hero">
      <div class="project-hero__main">
        <h1 class="project-hero__title animate">
          {project.data.title}
        </h1>
        {
          (project.data.demoURL || project.data.repoURL) && (
            <nav class="project-hero__links animate">
              {project.data.demoURL && (
                <Link href={project.data.demoURL} external>
                  {project.data.demoText}
                </Link>
              )}
              {project.data.demoURL && project.data.repoURL && (
                <span>&nbsp;/&nbsp;</span>
              )}
              {project.data.repoURL && (
                <Link href={project.data.repoURL} external>
                  {project.data.repoText}
                </Link>
              )}
            </nav>
          )
        }
      </div>
      <div class="project-hero__desc">
        <h2 class="project-hero__desc-title animate">
          {project.data.description}
        </h2>
      </div>
    </div>
    <div class="project-hero-image">
      <Image
        class="project-hero-image__img"
        src={project.data.heroImage}
        alt={project.data.heroImageAlt}
        width={1200}
        height={800}
        quality={"high"}
        densities={[1, 2]}
        loading="eager"
      />
    </div>
    <article class="project-article">
      {
        project.data.challenge && (
          <div class="project-article__block animate">
            <h3 class="project-article__heading">Challenge</h3>
            <p class="project-article__p">{project.data.challenge}</p>
          </div>
        )
      }
      {
        project.data.solution && (
          <div class="project-article__block animate">
            <h3 class="project-article__heading">Solution</h3>
            <p class="project-article__p">{project.data.solution}</p>
          </div>
        )
      }
      {
        project.data.results && (
          <div class="project-article__block animate">
            <h3 class="project-article__heading">Results</h3>
            <p class="project-article__p">{project.data.results}</p>
          </div>
        )
      }
      <div class="project-article__block animate">
        <h3 class="project-article__heading">Areas of Expertise</h3>
        <ul class="project-article__tags">
          {
            project.data.tags.map((tag) => (
              <li class="project-article__tag">{tag}</li>
            ))
          }
        </ul>
      </div>
    </article>
    <article class="project-content animate">
      <Content />
    </article>
    <PostNav prev={prev} next={next} topSpacing="md" />
  </Container>
</PageLayout>

<style>
  .project-hero {
    width: 100%;
    margin-inline: auto;
    margin-top: var(--space-4);
    margin-bottom: var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 1024px) {
    .project-hero {
      margin-top: var(--space-16);
      margin-bottom: var(--space-16);
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  .project-hero__title {
    font-size: var(--text-5xl);
    font-weight: var(--font-semibold);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    max-inline-size: var(--measure-title);
    text-wrap: balance;
    color: var(--color-surface-950);
    margin: 0;
  }

  @media (min-width: 1024px) {
    .project-hero__title {
      font-size: var(--text-6xl);
    }
  }

  .project-hero__links {
    margin-top: var(--space-4);
    display: flex;
    gap: var(--space-1);
  }

  .project-hero__desc {
    margin-top: var(--space-4);
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .project-hero__desc {
      margin-top: 0;
    }
  }

  .project-hero__desc-title {
    font-size: var(--text-xl);
    font-weight: 300;
    line-height: var(--leading-body);
    color: var(--color-surface-950);
    margin: 0;
    max-inline-size: var(--measure-copy);
    width: 100%;
    text-wrap: pretty;
  }

  @media (min-width: 1024px) {
    .project-hero__desc-title {
      font-size: var(--text-2xl);
    }
  }

  .project-hero-image {
    margin-bottom: var(--space-8);
  }

  .project-hero-image__img {
    width: 100%;
    height: 18rem;
    object-fit: cover;
    background-color: var(--color-surface-600);
    border-radius: var(--radius-md);
  }

  @media (min-width: 768px) {
    .project-hero-image__img {
      height: 36rem;
    }
  }

  @media (min-width: 1024px) {
    .project-hero-image__img {
      height: 48rem;
    }
  }

  .project-article {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-16);
    margin-bottom: var(--space-24);
  }

  .project-article__heading {
    font-size: var(--text-sm);
    line-height: var(--leading-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-weight: 400;
    padding-top: var(--space-4);
    margin-bottom: var(--space-4);
    margin-top: 0;
    border-top: 1px solid rgb(from var(--color-surface-950) r g b / 0.2);
  }

  @media (min-width: 768px) {
    .project-article__heading {
      padding-top: var(--space-6);
      margin-bottom: var(--space-6);
    }
  }

  .project-article__p {
    margin: 0;
  }

  .project-article__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .project-article__tag {
    padding-inline: var(--space-3);
    padding-block: var(--space-1);
    border-radius: var(--radius-md);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background-color: rgb(from var(--color-surface-950) r g b / 0.1);
    margin: 0;
    font-size: var(--text-base);
  }

  .project-content {
    margin-top: var(--space-12);
  }

  .project-content :global(.project-mdx-lead) {
    font-family: var(--font-sans);
    font-size: var(--text-4xl);
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--color-surface-950);
    margin-top: 0;
    margin-bottom: var(--space-8);
    max-width: 58rem;
    max-inline-size: 58rem;
    text-wrap: balance;
  }

  @media (min-width: 1024px) {
    .project-content :global(.project-mdx-lead) {
      font-size: var(--text-4_5xl);
      line-height: 1.1;
      margin-bottom: var(--space-10);
    }
  }

  .project-content :global(.project-mdx-columns) {
    width: 100%;
    column-gap: var(--space-10);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .project-content :global(.project-mdx-columns) {
      columns: 2;
    }
  }

  .project-content :global(.project-mdx-body) {
    font-size: var(--text-lg);
    line-height: 1.7;
    max-width: var(--container-readable);
    text-wrap: pretty;
  }

  .project-content :global(.project-mdx-body--first) {
    margin-top: 0;
    padding-top: 0;
  }

  .project-content :global(.project-mdx-gallery) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .project-content :global(.project-mdx-gallery > div) {
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .project-content :global(.project-mdx-gallery__item--full) {
    grid-column: span 2 / span 2;
  }

  .project-content :global(.project-mdx-gallery img) {
    display: block;
    width: 100%;
    margin: 0;
    border-radius: inherit;
  }

</style>
