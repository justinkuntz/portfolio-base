---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import Image from "astro/components/Image.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { collection } = project;
const { Content } = await project.render();

const items = (await getCollection(collection))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const index = items.findIndex((x) => x.slug === project.slug);
const prev = items[(index - 1 + items.length) % items.length];
const next = items[(index + 1) % items.length];
---

<PageLayout
  title={project.data.title}
  description={project.data.description || ""}
>
  <Container size="xl">
    <div class="project-hero">
      <div class="project-hero__main">
        <h1 class="project-hero__title animate">
          {project.data.title}
        </h1>
        {
          (project.data.demoURL || project.data.repoURL) && (
            <nav class="project-hero__links animate">
              {project.data.demoURL && (
                <Link href={project.data.demoURL} external>
                  {project.data.demoText}
                </Link>
              )}
              {project.data.demoURL && project.data.repoURL && (
                <span>&nbsp;/&nbsp;</span>
              )}
              {project.data.repoURL && (
                <Link href={project.data.repoURL} external>
                  {project.data.repoText}
                </Link>
              )}
            </nav>
          )
        }
      </div>
      <div class="project-hero__desc">
        <h2 class="project-hero__desc-title animate">
          {project.data.description}
        </h2>
      </div>
    </div>
    <div class="project-hero-image">
      <Image
        class="project-hero-image__img"
        src={project.data.heroImage}
        alt={project.data.heroImageAlt}
        width={1200}
        height={800}
        quality={"high"}
        densities={[1, 2]}
        loading="eager"
      />
    </div>
    <article class="project-article">
      {
        project.data.challenge && (
          <div class="project-article__block animate">
            <h3 class="project-article__heading">Challenge</h3>
            <p class="project-article__p">{project.data.challenge}</p>
          </div>
        )
      }
      {
        project.data.solution && (
          <div class="project-article__block animate">
            <h3 class="project-article__heading">Solution</h3>
            <p class="project-article__p">{project.data.solution}</p>
          </div>
        )
      }
      {
        project.data.results && (
          <div class="project-article__block animate">
            <h3 class="project-article__heading">Results</h3>
            <p class="project-article__p">{project.data.results}</p>
          </div>
        )
      }
      <div class="project-article__block animate">
        <h3 class="project-article__heading">Areas of Expertise</h3>
        <ul class="project-article__tags">
          {
            project.data.tags.map((tag) => (
              <li class="project-article__tag">{tag}</li>
            ))
          }
        </ul>
      </div>
    </article>
    <article class="project-content animate">
      <Content />
    </article>
    <div class="post-nav">
      <Link href={`/${prev.collection}/${prev.slug}`} class="post-nav__card post-nav__card--prev">
        <span class="post-nav__body">
          <span class="post-nav__label">Prev</span>
          <span class="post-nav__title">{prev.data.title}</span>
        </span>
        <svg class="post-nav__arrow arrow-animated arrow-animated--left post-nav__arrow--left" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line"></line>
          <polyline points="12 5 19 12 12 19" class="arrow-animated__poly"></polyline>
        </svg>
      </Link>
      <Link href={`/${next.collection}/${next.slug}`} class="post-nav__card post-nav__card--next">
        <span class="post-nav__body post-nav__body--right">
          <span class="post-nav__label">Next</span>
          <span class="post-nav__title">{next.data.title}</span>
        </span>
        <svg class="post-nav__arrow arrow-animated" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line"></line>
          <polyline points="12 5 19 12 12 19" class="arrow-animated__poly"></polyline>
        </svg>
      </Link>
    </div>
  </Container>
</PageLayout>

<style>
  .project-hero {
    width: 100%;
    margin-inline: auto;
    margin-top: var(--space-4);
    margin-bottom: var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 1024px) {
    .project-hero {
      margin-top: var(--space-16);
      margin-bottom: var(--space-16);
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  .project-hero__title {
    font-size: var(--text-5xl);
    font-weight: var(--font-semibold);
    color: var(--color-surface-950);
    margin: 0;
  }

  @media (min-width: 1024px) {
    .project-hero__title {
      font-size: var(--text-6xl);
    }
  }

  .project-hero__links {
    margin-top: var(--space-4);
    display: flex;
    gap: var(--space-1);
  }

  .project-hero__desc {
    margin-top: var(--space-4);
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .project-hero__desc {
      margin-top: 0;
    }
  }

  .project-hero__desc-title {
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-surface-950);
    margin: 0;
    max-inline-size: none;
    width: 100%;
    text-wrap: wrap;
  }

  @media (min-width: 1024px) {
    .project-hero__desc-title {
      font-size: var(--text-2xl);
    }
  }

  .project-hero-image {
    margin-bottom: var(--space-8);
  }

  .project-hero-image__img {
    width: 100%;
    height: 18rem;
    object-fit: cover;
    background-color: var(--color-surface-600);
  }

  @media (min-width: 768px) {
    .project-hero-image__img {
      height: 36rem;
    }
  }

  @media (min-width: 1024px) {
    .project-hero-image__img {
      height: 48rem;
    }
  }

  .project-article {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-16);
    margin-bottom: var(--space-24);
  }

  .project-article__heading {
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
    padding-top: var(--space-4);
    margin-bottom: var(--space-4);
    margin-top: 0;
    border-top: 1px solid rgb(from var(--color-surface-950) r g b / 0.2);
  }

  @media (min-width: 768px) {
    .project-article__heading {
      padding-top: var(--space-6);
      margin-bottom: var(--space-6);
    }
  }

  .project-article__p {
    margin: 0;
  }

  .project-article__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .project-article__tag {
    padding-inline: var(--space-3);
    padding-block: var(--space-1);
    border-radius: var(--radius-md);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background-color: rgb(from var(--color-surface-950) r g b / 0.1);
    margin: 0;
    font-size: var(--text-base);
  }

  .project-content {
    margin-top: var(--space-12);
  }

  .project-content :global(.text-pretty) {
    text-wrap: pretty;
  }

  .project-content :global(.text-4xl) {
    font-size: var(--text-3xl);
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .project-content :global(.text-4xl) {
      font-size: var(--text-4xl);
    }
  }

  .project-content :global(.font-normal) {
    font-weight: var(--font-normal);
  }

  .project-content :global(.max-w-readable) {
    max-width: var(--container-readable);
  }

  .project-content :global(.text-lg) {
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .project-content :global(.w-full) {
    width: 100%;
  }

  .project-content :global(.mb-16) {
    margin-bottom: var(--space-16);
  }

  .project-content :global(.mt-0) {
    margin-top: 0;
  }

  .project-content :global(.pt-0) {
    padding-top: 0;
  }

  .project-content :global(.gap-10) {
    gap: var(--space-10);
  }

  .project-content :global(.gap-6) {
    gap: var(--space-6);
  }

  .project-content :global(.md\:columns-2) {
    column-gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .project-content :global(.md\:columns-2) {
      columns: 2;
    }
  }

  .project-content :global(.md\:columns-2 > *) {
    break-inside: avoid;
    margin-bottom: var(--space-6);
  }

  .project-content :global(.md\:columns-2 > *:last-child) {
    margin-bottom: 0;
  }

  .project-content :global(.grid) {
    display: grid;
  }

  .project-content :global(.grid-cols-2) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project-content :global(.col-span-2) {
    grid-column: span 2 / span 2;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-12);
  }

  .post-nav__card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid rgb(from var(--color-surface-950) r g b / 0.15);
    border-radius: var(--radius-lg);
    color: currentColor;
    text-decoration: none;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .post-nav__card:hover {
    background-color: rgb(from var(--color-surface-950) r g b / 0.05);
  }

  .post-nav__card:hover .post-nav__title,
  .post-nav__card:hover .post-nav__arrow {
    color: var(--color-surface-950);
    stroke: var(--color-surface-950);
  }

  .post-nav__card--prev .post-nav__arrow--left {
    order: -1;
    transform: rotate(180deg);
  }

  .post-nav__body {
    flex: 1;
    min-width: 0;
  }

  .post-nav__body--right {
    text-align: right;
  }

  .post-nav__label {
    font-size: var(--text-sm);
    text-transform: uppercase;
  }

  .post-nav__title {
    display: block;
    font-weight: var(--font-semibold);
    margin-top: var(--space-3);
    color: var(--color-surface-950);
    transition: color var(--transition-base);
  }

  .post-nav__arrow {
    flex-shrink: 0;
    stroke: currentColor;
    transition: stroke var(--transition-base);
  }
</style>
