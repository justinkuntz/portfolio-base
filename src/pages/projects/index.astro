---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Projects from "@components/Projects";
import { PROJECTS, PROJECTS_LISTING } from "@consts";
import { toProjectCardEntries } from "@lib/images";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tags = [
  ...new Set(projects.flatMap((project) => project.data.tags)),
].sort((a, b) => a.localeCompare(b));

const projectCards = await toProjectCardEntries(projects);
---

<PageLayout
  title={PROJECTS.TITLE}
  description={PROJECTS.DESCRIPTION}
  seo={{ kind: "page", generatedImage: true }}
>
  <Container size="xl">
    <div class="page-intro page-intro--projects">
      <h1 class="page-intro__title animate">
        Projects
      </h1>
      <p class="page-intro__description">
        Sample case studies that demonstrate the project collection, tag
        filtering, and image-heavy MDX layouts.
      </p>
    </div>
    <div class="animate">
      <Projects
        client:idle
        tags={tags}
        data={projectCards}
        gridColumns={PROJECTS_LISTING.GRID_COLUMNS}
      />
    </div>
  </Container>
</PageLayout>

<style>
  .page-intro--projects {
    margin-top: var(--space-10);
  }

  @media (min-width: 768px) {
    .page-intro--projects {
      margin-top: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .page-intro--projects {
      margin-top: var(--space-24);
    }
  }
</style>
