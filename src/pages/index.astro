---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard";
import Button from "@components/Button.astro";
import { SITE, HOME } from "@consts";
import { Image } from "astro:assets";
import profileImage from "@assets/temp-profile.avif";
import AnimatedProjects from "@components/AnimatedProjects.tsx";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container size="xl">
    <div class="home">
      <section class="home__hero">
        <article class="home__hero-content">
          <div class="home__hero-text">
            <h1 class="home__headline animate">
              An illustrator, engineer, and designer from Oregon.
            </h1>
            <h2 class="home__greeting animate">I'm Popeye,</h2>
          </div>
          <p class="home__description animate">
            I am passionate about creativity and technology. I love to create
            things that are not only functional but also beautiful.
          </p>
          <div class="home__actions animate">
            <Button href="/projects" variant="primary" size="lg" iconRight="arrow">
              See my work
            </Button>
            <Button href="/about" variant="outline" size="lg">
              About me
            </Button>
          </div>
        </article>
        <div class="home__image-wrap">
          <Image
            class="home__image animate"
            src={profileImage}
            alt="Popeye the Sailor"
            width={800}
            height={800}
            quality={"high"}
            densities={[1, 2]}
          />
        </div>
      </section>

      <section class="home__section animate">
        <div class="home__section-head">
          <h2 class="home__section-title">
            <a href="/projects" class="home__section-link">
              Projects
              <svg class="home__section-icon arrow-animated" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line" />
                <polyline points="12 5 19 12 12 19" class="arrow-animated__poly" />
              </svg>
            </a>
          </h2>
        </div>
        <AnimatedProjects projects={projects} client:load />
      </section>

      <section class="home__section animate">
        <div class="home__section-head">
          <h2 class="home__section-title">
            <a href="/blog" class="home__section-link">
              Writing
              <svg class="home__section-icon arrow-animated" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" class="arrow-animated__line" />
                <polyline points="12 5 19 12 12 19" class="arrow-animated__poly" />
              </svg>
            </a>
          </h2>
        </div>
        <ul class="home__blog-list">
          {
            blog.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .home__hero {
    display: grid;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .home__hero {
      grid-template-columns: repeat(12, 1fr);
    }
  }

  .home__hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-height: fit-content;
  }

  @media (min-width: 768px) {
    .home__hero-content {
      grid-column: span 7;
    }
  }

  .home__hero-text {
    display: flex;
    flex-direction: column-reverse;
  }

  .home__greeting {
    font-weight: 400;
    color: var(--color-surface-950);
    margin-top: 0;
  }

  .home__headline {
    font-weight: var(--font-bold);
    color: var(--color-surface-950);
    font-size: var(--text-5xl);
    letter-spacing: -0.025em;
    margin-bottom: var(--space-4);
  }

  @media (min-width: 768px) {
    .home__headline {
      font-size: var(--text-6xl);
    }
  }

  @media (min-width: 1024px) {
    .home__headline {
      font-size: var(--text-7xl);
    }
  }

  .home__description {
    font-size: var(--text-lg);
  }

  @media (min-width: 768px) {
    .home__description {
      font-size: var(--text-xl);
    }
  }

  .home__actions {
    padding-top: var(--space-6);
    display: flex;
    gap: var(--space-4);
    height: fit-content;
  }

  .home__image-wrap {
    position: relative;
    order: -1;
    display: flex;
    align-items: center;
  }

  @media (min-width: 768px) {
    .home__image-wrap {
      grid-column: span 5;
      order: unset;
    }
  }

  .home__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-md);
    background-color: var(--color-surface-600);
  }

  @media (min-width: 768px) {
    .home__image {
      height: auto;
    }
  }

  .home__section {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .home__section-head {
    padding-top: var(--space-6);
    height: fit-content;
  }

  .home__section-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    color: rgb(from var(--color-surface-950) r g b / 0.4);
  }

  @media (min-width: 640px) {
    .home__section-title {
      font-size: var(--text-3xl);
    }
  }

  .home__section-link {
    display: inline-flex;
    gap: var(--space-1);
    align-items: center;
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .home__section-link:hover {
    color: rgb(from var(--color-surface-950) r g b / 0.6);
  }

  .home__section-icon {
    width: 1.6rem;
    height: 1.6rem;
    margin-left: var(--space-0.5);
    margin-right: -0.25rem;
    transform: translateY(0.05em);
  }

  .home__blog-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    padding-inline-start: 0;
    margin: 0;
  }

  .home__blog-list > li {
    padding-inline-start: 0;
  }

  @media (min-width: 1024px) {
    .home__blog-list {
      grid-template-columns: repeat(3, 1fr);
      max-width: none;
    }
  }
</style>
