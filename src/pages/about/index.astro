---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";
import { ABOUT } from "@consts";
import { Image } from "astro:assets";
import aboutImageOne from "@assets/grogu-and-din.jpg";
import aboutImageTwo from "@assets/luke-and-grogu.jpg";
import aboutImageThree from "@assets/grogu-and-ashoka.png";

const collection = (await getCollection("work")).sort(
  (a, b) =>
    new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf(),
);

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);
---

<PageLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container size="xl">
    <div class="about">
      <div class="about__hero">
        <div class="about__hero-text">
          <h1 class="about__title animate">
            Grogu is still small, but the ambition is very Mandalorian.
          </h1>
          <p class="about__intro animate">
            This starter uses Grogu as a light-hearted placeholder persona:
            observant, determined, and steadily learning what it means to carry
            responsibility with style.
          </p>
        </div>
        <div class="about__hero-images">
          <div class="about__hero-images-col about__hero-images-col--main">
            <div class="about__img-wrap">
              <Image
                class="about__img"
                src={aboutImageOne}
                alt="Sample portrait"
                width={800}
                height={800}
                quality={"high"}
                densities={[1, 2]}
              />
            </div>
          </div>
          <div class="about__hero-images-col about__hero-images-col--side">
            <div class="about__img-wrap about__img-wrap--pt">
              <Image
                class="about__img"
                src={aboutImageTwo}
                alt="Sample working session"
                width={800}
                height={800}
                quality={"high"}
                densities={[1, 2]}
              />
            </div>
            <div class="about__img-wrap about__img-wrap--hidden">
              <Image
                class="about__img"
                src={aboutImageThree}
                alt="Sample studio portrait"
                width={800}
                height={800}
                quality={"high"}
                densities={[1, 2]}
              />
            </div>
          </div>
        </div>
      </div>
      <div class="about__grid">
        <div class="about__content">
          <p class="about__p animate">
            Grogu does not say much, which is useful when building a portfolio.
            The work speaks first: patient iteration, careful instincts, and a
            refusal to rush into battle without understanding the terrain.
          </p>
          <p class="about__p animate">
            Under Din Djarin's watch, he has learned the basics of travel,
            trust, and survival. Under the Armorer, he is learning discipline,
            ritual, and how identity becomes stronger when it is chosen.
          </p>
          <p class="about__p animate">
            That makes him a useful placeholder for this template. The voice is
            playful, but the structure is practical: a hero, a readable bio, a
            timeline, and enough room to explain how you work without turning
            the page into a wall of lore.
          </p>
          <p class="about__p animate">
            Replace Grogu when you are ready. Until then, he can stand watch
            over the starter and remind you that every polished portfolio began
            as a foundling with borrowed armor and a lot to learn.
          </p>
        </div>
        <div class="about__timeline">
          <h2 class="about__timeline-title animate">Experience</h2>
          {
            work.map((entry) => (
              <div class="about__timeline-item">
                <div class="about__timeline-role animate">
                  {entry.data.role}
                </div>
                <div class="about__timeline-company animate">
                  {entry.data.company}
                </div>
                <div class="about__timeline-date-row">
                  <span class="about__timeline-dot-cell">
                    <span
                      class="about__timeline-dot animate"
                      aria-hidden="true"
                    />
                  </span>
                  <time class="about__timeline-date animate">
                    {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                  </time>
                </div>
                <div class="about__timeline-desc animate">
                  <entry.Content />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</PageLayout>

<style>
  .about {
    position: relative;
  }

  .about__hero {
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .about__hero {
      gap: var(--space-12);
    }
  }

  @media (min-width: 1024px) {
    .about__hero {
      flex-direction: row;
      align-items: center;
    }
  }

  .about__hero-text {
    position: relative;
  }

  @media (min-width: 1024px) {
    .about__hero-text {
      width: 50%;
    }
  }

  .about__title {
    font-size: var(--text-5xl);
    font-weight: var(--font-bold);
    letter-spacing: -0.025em;
    color: var(--color-surface-950);
    margin: 0 0 var(--space-8);
  }

  @media (min-width: 768px) {
    .about__title {
      font-size: var(--text-6xl);
    }
  }

  @media (min-width: 1024px) {
    .about__title {
      font-size: var(--text-7xl);
    }
  }

  .about__intro {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: rgb(from var(--color-surface-950) r g b / 0.8);
    max-width: var(--container-readable);
  }

  @media (min-width: 640px) {
    .about__intro {
      font-size: 1.25rem;
      line-height: 1.5;
    }
  }

  .about__hero-images {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-6);
    padding-block: var(--space-8);
  }

  @media (min-width: 1024px) {
    .about__hero-images {
      width: 50%;
    }
  }

  .about__hero-images-col--main {
    width: 50%;
  }

  @media (min-width: 768px) {
    .about__hero-images-col--main {
      width: 33.333%;
    }
  }

  @media (min-width: 1024px) {
    .about__hero-images-col--main {
      width: 60%;
    }
  }

  .about__hero-images-col--main .about__img-wrap {
    padding-top: 0;
  }

  @media (min-width: 1024px) {
    .about__hero-images-col--main .about__img-wrap {
      padding-top: var(--space-24);
    }
  }

  .about__hero-images-col--side {
    width: 50%;
    display: flex;
    flex-direction: row;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .about__hero-images-col--side {
      width: 40%;
      flex-direction: column;
      padding-top: 0;
    }
  }

  .about__img-wrap {
    position: relative;
    flex: 1;
  }

  .about__img-wrap--pt {
    padding-top: var(--space-12);
  }

  @media (min-width: 1024px) {
    .about__img-wrap--pt {
      padding-top: 0;
    }
  }

  .about__img-wrap--hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .about__img-wrap--hidden {
      display: block;
    }
  }

  .about__img {
    width: 100%;
    height: 16rem;
    object-fit: cover;
    border-radius: var(--radius-md);
    background-color: var(--color-surface-600);
  }

  @media (min-width: 768px) {
    .about__img {
      height: 24rem;
    }
  }

  @media (min-width: 1024px) {
    .about__img {
      height: auto;
    }
  }

  .about__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .about__grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: var(--space-16);
      align-items: start;
    }
  }

  .about__content {
    position: relative;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .about__content {
      grid-column: 1 / span 7;
    }
  }

  .about__p {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-4);
  }

  .about__p:last-of-type {
    margin-bottom: 0;
  }

  .about__timeline {
    position: relative;
    padding-top: var(--space-12);
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .about__timeline {
      grid-column: 8 / -1;
      padding-top: 0;
    }
  }

  .about__timeline-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    color: rgb(from var(--color-surface-950) r g b / 0.4);
    padding-left: calc(var(--space-8) + var(--space-4));
    margin: 0 0 var(--space-4);
  }

  .about__timeline-item {
    display: grid;
    grid-template-columns: var(--space-8) 1fr;
    grid-template-rows: auto auto auto 1fr;
    gap: 0 var(--space-4);
    padding-block: var(--space-6);
    position: relative;
  }

  .about__timeline-item::before {
    content: "";
    grid-column: 1;
    grid-row: 1 / -1;
    justify-self: center;
    width: 1px;
    background-color: var(--color-surface-200);
    margin-top: calc(-1 * var(--space-6));
    margin-bottom: calc(-1 * var(--space-6));
  }

  .about__timeline-date-row {
    grid-column: 1 / -1;
    grid-row: 3;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .about__timeline-dot-cell {
    width: var(--space-8);
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .about__timeline-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background-color: var(--color-surface-700);
    border: 4px solid var(--color-surface-400);
    box-sizing: content-box;
    flex-shrink: 0;
  }

  .about__timeline-role {
    grid-column: 2;
    grid-row: 1;
    font-weight: var(--font-medium);
    font-size: var(--text-xl);
    color: var(--color-surface-950);
    margin: 0;
  }

  .about__timeline-company {
    grid-column: 2;
    grid-row: 2;
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: rgb(from var(--color-surface-950) r g b / 0.6);
    margin: 0 0 var(--space-3);
  }

  .about__timeline-date {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    padding: var(--space-1) var(--space-2);
    background-color: rgb(from var(--color-surface-950) r g b / 0.08);
    color: rgb(from var(--color-surface-950) r g b / 0.7);
    border-radius: var(--radius-full);
    /* border: 1px solid rgb(from var(--color-surface-950) r g b / 0.15); */
  }

  .about__timeline-desc {
    grid-column: 2;
    grid-row: 4;
    color: rgb(from var(--color-surface-950) r g b / 0.5);
    font-size: var(--text-base);
    line-height: 1.6;
    margin: 0;
  }

  .about__timeline-desc :global(p) {
    margin: 0 0 var(--space-3);
  }

  .about__timeline-desc :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
