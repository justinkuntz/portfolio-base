---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";
import { WORK } from "@consts";
import { Image } from "astro:assets";
import aboutImageOne from "@assets/about-photo-1559136555.avif";
import aboutImageTwo from "@assets/about-photo-1670272505284.avif";
import aboutImageThree from "@assets/about-photo-1670272504528.avif";
import oliveOyl from "@assets/olive-oyl.jpeg";

const collection = (await getCollection("work")).sort(
  (a, b) =>
    new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf()
);

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container size="xl">
    <div class="about">
      <div class="about__hero">
        <div class="about__hero-text">
          <h1 class="about__title animate">
            I yam wot I yam, and that's all wot I yam, I'm Popeye the Sailor
            Man
          </h1>
          <p class="about__intro animate">
            Popeye is a one-of-a-kind hybrid creative: part designer, part
            illustrator, part engineer. Fueled by equal parts ingenuity and a
            secret stash of "spinach" inspiration, he tackles challenges
            others deem impossible. Whether sketching bold concepts,
            prototyping mechanical marvels, or crafting pixel-perfect
            interfaces, Popeye turns every problem into an opportunity to flex
            his creative muscles.
          </p>
        </div>
        <div class="about__hero-images">
          <div class="about__hero-images-col about__hero-images-col--main">
            <div class="about__img-wrap">
              <Image
                class="about__img"
                src={aboutImageOne}
                alt="Popeye the Sailor"
                width={800}
                height={800}
                quality={"high"}
                densities={[1, 2]}
              />
            </div>
          </div>
          <div class="about__hero-images-col about__hero-images-col--side">
            <div class="about__img-wrap about__img-wrap--pt">
              <Image
                class="about__img"
                src={aboutImageTwo}
                alt="Popeye the Sailor"
                width={800}
                height={800}
                quality={"high"}
                densities={[1, 2]}
              />
            </div>
            <div class="about__img-wrap about__img-wrap--hidden">
              <Image
                class="about__img"
                src={aboutImageThree}
                alt="Popeye the Sailor"
                width={800}
                height={800}
                quality={"high"}
                densities={[1, 2]}
              />
            </div>
          </div>
        </div>
      </div>
      <div class="about__grid">
        <div class="about__content">
          <p class="about__p animate">
            Born with an uncanny knack for solving puzzles, Popeye first
            discovered his design "luck" in an unlikely way—by rubbing the feather
            of a legendary bird that granted him boundless endurance and a
            fearless sense of experimentation. Early in his career, he was known
            to survive fifteen simultaneous branding crises, emerging each time
            with stronger, smarter solutions. Over time, he traded out his
            mystical feather for something more reliable: a steady diet of
            spinach-like curiosity and relentless self-study.
          </p>
          <p class="about__p animate">
            As an illustrator, Popeye's bold, expressive lines capture both whimsy
            and precision. He's spent countless nights refining characters that
            dance off the page, from sleek product mockups to vibrant storyboards.
            His portfolio spans children's books, branding campaigns, and public
            installations—each infused with his signature blend of humor and
            meticulous detail.
          </p>
          <p class="about__p animate">
            On the engineering side, Popeye earns his reputation for building
            ingenious prototypes. His trusty pipe doubles as a micro CNC cutter,
            3D filament extruder, and even a makeshift periscope when deadlines
            loom. He's reverse-engineered complex gears, developed custom
            Arduino-driven interfaces, and seamlessly integrated digital and
            physical systems. When others see a wall, Popeye sees a lever and
            pulley waiting to be designed.
          </p>
          <p class="about__p animate">
            Despite occasional tussles in the classic love triangle of form,
            function, and feasibility—his version of Olive Oyl and Bluto—Popeye's
            near-saintly perseverance always prevails. He advocates that great
            design must serve real people, not just impress the scientific
            community. With every project, he proves that a blend of creative
            vision, technical rigor, and a can-do attitude can conquer any
            obstacle—no spinach required.
          </p>
          <figure class="about__quote">
            <blockquote class="about__quote-text">
              <p>
                "I heard that a camel can go 9 days without water. -A trivial
                thing. Going 9 days without a hamburgers, would be an
                accomplishment worthy of my admiration."
              </p>
            </blockquote>
            <figcaption class="about__quote-caption">
              <Image
                class="about__quote-avatar"
                src={oliveOyl}
                alt="Olive Oyl"
                width={400}
                height={400}
                quality={"high"}
                densities={[1, 2]}
              />
              <div class="about__quote-meta">
                <div class="about__quote-name">Olive Oyl</div>
                <div class="about__quote-handle">@oliveoyl</div>
              </div>
            </figcaption>
          </figure>
        </div>
        <div class="about__timeline">
          <h2 class="about__timeline-title animate">Experience</h2>
          {
            work.map((entry) => (
              <div class="about__timeline-item">
                <div class="about__timeline-role animate">{entry.data.role}</div>
                <div class="about__timeline-company animate">{entry.data.company}</div>
                <div class="about__timeline-date-row">
                  <span class="about__timeline-dot-cell">
                    <span class="about__timeline-dot animate" aria-hidden="true"></span>
                  </span>
                  <time class="about__timeline-date animate">
                    {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                  </time>
                </div>
                <div class="about__timeline-desc animate">
                  <entry.Content />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</PageLayout>

<style>
  .about {
    position: relative;
  }

  .about__hero {
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .about__hero {
      gap: var(--space-12);
    }
  }

  @media (min-width: 1024px) {
    .about__hero {
      flex-direction: row;
      align-items: center;
    }
  }

  .about__hero-text {
    position: relative;
  }

  @media (min-width: 1024px) {
    .about__hero-text {
      width: 50%;
    }
  }

  .about__title {
    font-size: var(--text-5xl);
    font-weight: var(--font-bold);
    letter-spacing: -0.025em;
    color: var(--color-surface-950);
    margin: 0 0 var(--space-8);
  }

  @media (min-width: 768px) {
    .about__title {
      font-size: var(--text-6xl);
    }
  }

  @media (min-width: 1024px) {
    .about__title {
      font-size: var(--text-7xl);
    }
  }

  .about__intro {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: rgb(from var(--color-surface-950) r g b / 0.8);
    max-width: var(--container-readable);
  }

  @media (min-width: 640px) {
    .about__intro {
      font-size: 1.25rem;
      line-height: 1.5;
    }
  }

  .about__hero-images {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-6);
    padding-block: var(--space-8);
  }

  @media (min-width: 1024px) {
    .about__hero-images {
      width: 50%;
    }
  }

  .about__hero-images-col--main {
    width: 50%;
  }

  @media (min-width: 768px) {
    .about__hero-images-col--main {
      width: 33.333%;
    }
  }

  @media (min-width: 1024px) {
    .about__hero-images-col--main {
      width: 60%;
    }
  }

  .about__hero-images-col--main .about__img-wrap {
    padding-top: 0;
  }

  @media (min-width: 1024px) {
    .about__hero-images-col--main .about__img-wrap {
      padding-top: var(--space-24);
    }
  }

  .about__hero-images-col--side {
    width: 50%;
    display: flex;
    flex-direction: row;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .about__hero-images-col--side {
      width: 40%;
      flex-direction: column;
      padding-top: 0;
    }
  }

  .about__img-wrap {
    position: relative;
    flex: 1;
  }

  .about__img-wrap--pt {
    padding-top: var(--space-12);
  }

  @media (min-width: 1024px) {
    .about__img-wrap--pt {
      padding-top: 0;
    }
  }

  .about__img-wrap--hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .about__img-wrap--hidden {
      display: block;
    }
  }

  .about__img {
    width: 100%;
    height: 16rem;
    object-fit: cover;
    border-radius: var(--radius-md);
    background-color: var(--color-surface-600);
  }

  @media (min-width: 768px) {
    .about__img {
      height: 24rem;
    }
  }

  @media (min-width: 1024px) {
    .about__img {
      height: auto;
    }
  }

  .about__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .about__grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: var(--space-16);
      align-items: start;
    }
  }

  .about__content {
    position: relative;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .about__content {
      grid-column: 1 / span 7;
    }
  }

  .about__p {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-4);
  }

  .about__p:last-of-type {
    margin-bottom: 0;
  }

  .about__quote {
    margin-top: var(--space-12);
    margin-bottom: var(--space-12);
    /* margin-left: calc(-1 * var(--space-4)); */
    padding-left: var(--space-6);
    padding-block: var(--space-4);
    border-left: 4px solid rgb(from var(--color-surface-950) r g b / 0.3);
  }

  .about__quote blockquote {
    border: none;
    padding: 0;
    padding-inline: 0;
    margin: 0;
    max-inline-size: none;
    width: 100%;
    display: block;
  }

  .about__quote blockquote p {
    padding-left: 0;
    padding-inline-start: 0;
    margin: 0;
    max-width: none;
  }

  @media (min-width: 768px) {
    .about__quote {
      margin-top: var(--space-24);
    }
  }

  .about__quote-text {
    font-size: var(--text-xl);
    line-height: 1.5;
    font-weight: var(--font-semibold);
    letter-spacing: -0.025em;
    color: var(--color-surface-950);
    margin: 0;
  }

  .about__quote-caption {
    margin-top: var(--space-4);
    margin-left: auto;
    margin-right: var(--space-4);
    width: fit-content;
    display: flex;
    gap: var(--space-4);
    align-items: center;
    justify-content: flex-end;
  }

  .about__quote-meta {
    text-align: right;
  }

  .about__quote-avatar {
    margin-top: var(--space-1);
    width: 2.5rem;
    height: 2.5rem;
    flex: none;
    border-radius: var(--radius-full);
    object-fit: cover;
    background-color: var(--color-surface-100);
  }

  .about__quote-name {
    font-size: var(--text-base);
    line-height: 1.5;
    font-weight: var(--font-semibold);
    color: rgb(from var(--color-surface-950) r g b / 0.6);
  }

  .about__quote-handle {
    color: rgb(from var(--color-surface-950) r g b / 0.3);
  }

  .about__timeline {
    position: relative;
    padding-top: var(--space-12);
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .about__timeline {
      grid-column: 8 / -1;
      padding-top: 0;
    }
  }

  .about__timeline-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    color: rgb(from var(--color-surface-950) r g b / 0.4);
    padding-left: calc(var(--space-8) + var(--space-4));
    margin: 0 0 var(--space-4);
  }

  .about__timeline-item {
    display: grid;
    grid-template-columns: var(--space-8) 1fr;
    grid-template-rows: auto auto auto 1fr;
    gap: 0 var(--space-4);
    padding-block: var(--space-6);
    position: relative;
  }

  .about__timeline-item::before {
    content: "";
    grid-column: 1;
    grid-row: 1 / -1;
    justify-self: center;
    width: 1px;
    background-color: var(--color-surface-200);
    margin-top: calc(-1 * var(--space-6));
    margin-bottom: calc(-1 * var(--space-6));
  }

  .about__timeline-date-row {
    grid-column: 1 / -1;
    grid-row: 3;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .about__timeline-dot-cell {
    width: var(--space-8);
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .about__timeline-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background-color: var(--color-surface-700);
    border: 4px solid var(--color-surface-400);
    box-sizing: content-box;
    flex-shrink: 0;
  }

  .about__timeline-role {
    grid-column: 2;
    grid-row: 1;
    font-weight: var(--font-medium);
    font-size: var(--text-xl);
    color: var(--color-surface-950);
    margin: 0;
  }

  .about__timeline-company {
    grid-column: 2;
    grid-row: 2;
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: rgb(from var(--color-surface-950) r g b / 0.6);
    margin: 0 0 var(--space-3);
  }

  .about__timeline-date {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    padding: var(--space-1) var(--space-2);
    background-color: rgb(from var(--color-surface-950) r g b / 0.08);
    color: rgb(from var(--color-surface-950) r g b / 0.7);
    border-radius: var(--radius-full);
    /* border: 1px solid rgb(from var(--color-surface-950) r g b / 0.15); */
  }

  .about__timeline-desc {
    grid-column: 2;
    grid-row: 4;
    color: rgb(from var(--color-surface-950) r g b / 0.5);
    font-size: var(--text-base);
    line-height: 1.6;
    margin: 0;
  }

  .about__timeline-desc :global(p) {
    margin: 0 0 var(--space-3);
  }

  .about__timeline-desc :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
