SITE_URL=https://example.com

# Contact form
RESEND_API_KEY=your-resend-api-key
CONTACT_FROM_EMAIL=noreply@example.com
CONTACT_TO_EMAIL=you@example.com

# Protected projects
PROJECT_ACCESS_SECRET=replace-this-with-a-long-random-secret
PROJECT_ACCESS_PASSWORD=replace-this-with-a-shared-password
PROJECT_ACCESS_NOTIFY_TO_EMAIL=you@example.com

# Optional per-project override
PROJECT_PASSWORD_ALCOHOLICVODKA=replace-this-with-a-password

# Optional JSON map of password ids to passwords
# PROJECT_ACCESS_PASSWORDS={"alcoholicvodka":"replace-this-with-a-password"}
